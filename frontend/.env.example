# Copy to `.env.local` (gitignored by Next defaults).

# Backend API origin reachable from the browser. NEXT_PUBLIC_* is inlined
# into the client bundle at build time, so use a host-reachable URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Server-only override used by route handlers (e.g. /api/register-proxy).
# Set when the server reaches the API on a different hostname than the
# browser does — typically inside Docker (e.g. http://backend:3000).
# API_BASE_URL=

# Verbose logging when NODE_ENV=development OR APP_ENV is local|test.
NEXT_PUBLIC_APP_ENV=local

# Server-only secret for /api/register-proxy. Must match the backend's
# AGENT_REGISTRATION_SECRET. Never prefix with NEXT_PUBLIC_.
AGENT_REGISTRATION_SECRET=

# Show the /register page in the UI.
NEXT_PUBLIC_SHOW_REGISTER=false
