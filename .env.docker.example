# ------------------------------------------------------------
# docker-compose environment for Smart Triage
#   cp .env.docker.example .env
#   (optionally) set OPENAI_API_KEY below
#   docker compose up --build
#
# Compose auto-loads this file and substitutes ${VAR} references
# in docker-compose.yml. Keys not listed here fall back to the
# defaults defined in the compose file. backend/.env and
# frontend/.env.local are NOT read by Docker.
# ------------------------------------------------------------

# Required for LLM triage to actually classify tickets.
# If left blank, tickets still create successfully; the worker
# exhausts retries and marks them triageStatus=failed with
# defaults (category=General, priority=medium).
OPENAI_API_KEY=

# Backend secrets — safe LOCAL-ONLY defaults. Replace in any
# shared environment.
JWT_SECRET=local-dev-only-change-me
AGENT_REGISTRATION_SECRET=local-agent-secret
ADMIN_REGISTRATION_SECRET=local-admin-secret

# Optional overrides (sensible defaults baked into compose):
# JWT_EXPIRES_IN=1d
# OPENAI_TRIAGE_MODEL=gpt-4o-mini

# Optional: Sentry
# SENTRY_DSN=
# SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_PROFILES_SAMPLE_RATE=0
