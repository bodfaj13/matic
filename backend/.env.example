# Database / queue
MONGODB_URI=mongodb://127.0.0.1:27017/codematicticketsystem
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
AGENT_REGISTRATION_SECRET=change-agent-secret
ADMIN_REGISTRATION_SECRET=  # leave blank to disable admin self-registration

# OpenAI triage worker
OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=gpt-4o-mini

# Server
PORT=3000
NODE_ENV=development
# APP_ENV=local                          # also exposes Swagger at /api/v1/docs

# Rate limiting
THROTTLE_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Optional: Sentry
# SENTRY_DSN=
# SENTRY_ENV=development
# SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_PROFILES_SAMPLE_RATE=0
